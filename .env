# You can put anything here for the key when using Ollama
OPENAI_API_KEY=ollama

# The name of the model you downloaded in Ollama (e.g., llama3, mistral, phi3)
OLLAMA_MODEL=llama3.2
# This tells the project to talk to your local computer instead of OpenAI
OLLAMA_BASE_URL=http://localhost:11434/v1


GOOGLE_SHEET_NAME=CustomerSupportEscalations
GOOGLE_CREDENTIALS_FILE=credentials.json
